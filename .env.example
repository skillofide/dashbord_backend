# ==========================================================================
# Environment variables required by dashbord_backend in production.
# Copy this file to .env and fill in real values — NEVER commit .env
# ==========================================================================

# ── Database (Amazon RDS PostgreSQL) ──────────────────────────────────────
POSTGRES_DSN=postgres://skillofide:<YOUR_DB_PASSWORD>@skillofide-db.czisgkemmwll.ap-south-1.rds.amazonaws.com:5432/skillofide?sslmode=require
DB_USER=skillofide
DB_PASSWORD=<YOUR_DB_PASSWORD>
DB_NAME=skillofide

# ── Redis (Amazon ElastiCache or self-hosted) ─────────────────────────────
REDIS_ADDR=<REDIS_HOST>:6379
REDIS_PASSWORD=<redis-password>

# ── NATS Messaging ────────────────────────────────────────────────────────
NATS_URL=nats://<NATS_HOST>:4222

# ── API Gateway ───────────────────────────────────────────────────────────
JWT_SECRET=<256-bit-random-secret>
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://app.yourdomain.com

# ── AWS (for CI/CD GitHub Actions) ───────────────────────────────────────
AWS_ACCOUNT_ID=<your-aws-account-id>
AWS_REGION=ap-south-1
ECR_REGISTRY=<account-id>.dkr.ecr.ap-south-1.amazonaws.com
